{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Coffer MCP Server (stdio)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "coffer_mcp.server"],
      "port": 0
    },
    {
      "name": "Coffer CLI",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "coffer_mcp.cli", "serve"],
      "port": 0
    },
    {
      "name": "Test Suite",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "pytest", "--tb=short", "-q"],
      "port": 0
    }
  ]
}
